# =============================================================================
# COBOL/JCL Migration Harness — environment variable reference
# =============================================================================
# Copy this file to `.env` and fill in real values for local dev / deployment.
# Every config value used anywhere in this repo MUST be sourced from `.env`
# (or a component's own `.env` in dev, per the "no hardcoding" project rule)
# — never hardcode a value that appears below into source code.
#
# Variables are grouped by the component(s) that read them. Some are shared
# across many components (e.g. COUCHDB_URL) and are only documented once,
# under the first/owning component.
# =============================================================================

# -----------------------------------------------------------------------------
# CouchDB — infra/couchdb/*, mcp_gateway/app/couchdb_client.py
# -----------------------------------------------------------------------------
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme_local_dev_only
# Logical DB names (used by init_databases.py and every reader of them so a
# rename is a config change, not a grep-and-replace).
COUCHDB_DB_SOURCES=sources
COUCHDB_DB_PARSED_STRUCTURE=parsed_structure
COUCHDB_DB_AGENT_RUNS=agent_runs
COUCHDB_DB_RECOMMENDATIONS=recommendations
COUCHDB_DB_BACKLOG=backlog
COUCHDB_DB_AUDIT_LOG=audit_log
COUCHDB_DB_CONFIG_META=config_meta

# -----------------------------------------------------------------------------
# Redis — orchestrator/celery_app.py, agents/common/kill_switch.py,
#          backend/job_pipeline_control_service/app/redis_client.py,
#          backend/review_bff (TTL cache)
# -----------------------------------------------------------------------------
# Single Redis instance, multiple logical DB indexes by convention:
#   0 = Celery broker + result backend
#   1 = general-purpose cache (BFF fan-out responses, skill-file content, etc.)
#   2 = kill-switch flags (kill:global, kill:project:<id>, kill:job:<id>)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_CELERY=0
REDIS_DB_CACHE=1
REDIS_DB_KILL_FLAGS=2
# Celery's broker/backend URL is derived from REDIS_HOST/REDIS_PORT/
# REDIS_PASSWORD/REDIS_DB_CELERY above (see orchestrator/celery_app.py) —
# not a separate literal here, so docker-compose's per-service REDIS_HOST
# override (e.g. "redis" for the container hostname) is never silently
# bypassed by a stale localhost value.
CACHE_TTL_SECONDS=60

# -----------------------------------------------------------------------------
# LiteLLM proxy (LLM gateway) — infra/litellm/litellm_config.yaml,
#          agents/common/llm_client.py
# -----------------------------------------------------------------------------
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-local-dev-master-key
# Logical model name agents request by default (never a literal provider
# string in agent/skill code — see litellm_config.yaml model_list).
DEFAULT_LOGICAL_MODEL=cobol-analysis-dev
# Some stages (e.g. codegen, generating a whole multi-file microservice in
# one completion) produce far more output tokens than a single-JSON-object
# response and can exceed a short default against a real commercial model —
# confirmed live: a Java Spring Boot generation for a story with 12-15
# detailed acceptance criteria can take several minutes.
LLM_CLIENT_TIMEOUT_SECONDS=480
# Commercial provider keys — commented out by default. Local dev and this
# pass's default pipeline run against a mock/echo model
# (cobol-analysis-mock, see infra/litellm/litellm_config.yaml), so no key is
# required to demo the system end to end.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VLLM_API_KEY=

# -----------------------------------------------------------------------------
# Guardrails service (NeMo Guardrails) — agents/common/guardrails_client.py
# -----------------------------------------------------------------------------
# NOTE: real container is deferred this pass (see docs/deferred_scope.md).
# guardrails_client.py is a local stub that performs real Pydantic schema
# validation but does not call this URL yet. Documented now so the seam is
# a config change, not a code change, once the real service exists.
GUARDRAILS_SERVICE_URL=http://localhost:8010

# -----------------------------------------------------------------------------
# Langfuse (agent observability) — agents/common/langfuse_client.py
# -----------------------------------------------------------------------------
# NOTE: real self-hosted Langfuse stack is deferred this pass (see
# docs/deferred_scope.md). langfuse_client.py logs spans locally (structured
# logs) instead of calling these. Documented now for the same reason as above.
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# -----------------------------------------------------------------------------
# MCP gateway — agents/common/mcp_client.py, backend/*/app (services that call
#          MCP tools directly, e.g. source_mgmt_service's mainframe pulls)
# -----------------------------------------------------------------------------
MCP_GATEWAY_URL=http://localhost:7000
MCP_GATEWAY_PORT=7000

# -----------------------------------------------------------------------------
# Codegen GitHub target — mcp_gateway/app/tools/codegen_tools.py. Generated
#          code is committed to this repo (one commit per generation run,
#          under a {story_id}/ folder), via the GitHub Git Data API — same
#          credential convention as the issue-tracker export's GitHub
#          adapter (a token, never a literal secret in code/config).
# -----------------------------------------------------------------------------
CODEGEN_GIT_REPO_OWNER=
CODEGEN_GIT_REPO_NAME=
CODEGEN_GIT_BRANCH=main
# CODEGEN_GIT_TOKEN=

# -----------------------------------------------------------------------------
# Kill-switch — mcp_gateway/app/tools/kill_tools.py,
#          backend/job_pipeline_control_service/app/routes/admin.py
# -----------------------------------------------------------------------------
# Admin bearer token required to call POST /admin/kill. Rotate per environment.
KILL_SWITCH_ADMIN_TOKEN=changeme_local_dev_admin_token

# -----------------------------------------------------------------------------
# Mainframe SCM connector — agents/mainframe_ingestion/*,
#          mcp_gateway/app/tools/mainframe_tools.py
# -----------------------------------------------------------------------------
# Selects the adapter behind mainframe.fetch_source. Only `mock` is runnable
# this pass; endevor/panvalet/changeman are real classes whose HTTP calls
# raise NotImplementedError (see docs/deferred_scope.md).
SCM_TOOL=mock

# Endevor (Broadcom) — REST API v2 / Endevor Web Services
MAINFRAME_ENDEVOR_HOST=
MAINFRAME_ENDEVOR_PORT=
MAINFRAME_ENDEVOR_AUTH_MODE=token
MAINFRAME_ENDEVOR_CREDENTIAL_REF=vault://mainframe/endevor/readonly

# ChangeMan ZMF (Micro Focus/Rocket) — REST API Server v8.1+
MAINFRAME_CHANGEMAN_HOST=
MAINFRAME_CHANGEMAN_PORT=
MAINFRAME_CHANGEMAN_AUTH_MODE=basic_tls
MAINFRAME_CHANGEMAN_CREDENTIAL_REF=vault://mainframe/changeman/readonly

# PanValet (CA/Broadcom) — realistic path is extract-to-PDS then z/OSMF
MAINFRAME_PANVALET_HOST=
MAINFRAME_PANVALET_PORT=
MAINFRAME_PANVALET_AUTH_MODE=basic_tls
MAINFRAME_PANVALET_CREDENTIAL_REF=vault://mainframe/panvalet/readonly

# -----------------------------------------------------------------------------
# Core API services — internal ports (800x), per architecture.md §10
# -----------------------------------------------------------------------------
SOURCE_MGMT_SERVICE_PORT=8004
SOURCE_MGMT_SERVICE_URL=http://localhost:8004
JOB_PIPELINE_CONTROL_SERVICE_PORT=8005
JOB_PIPELINE_CONTROL_SERVICE_URL=http://localhost:8005
RECOMMENDATION_SERVICE_PORT=8006
RECOMMENDATION_SERVICE_URL=http://localhost:8006
EPIC_STORY_SERVICE_PORT=8007
EPIC_STORY_SERVICE_URL=http://localhost:8007
# export_service intentionally not scaffolded this pass (see docs/deferred_scope.md)

# -----------------------------------------------------------------------------
# BFFs — ports 8001-8003, per architecture.md §8; codegen-bff added on 8008
# alongside the core API services block above (kept distinct from 8001-8003
# only because it was added after that block was numbered).
# -----------------------------------------------------------------------------
INGESTION_BFF_PORT=8001
INGESTION_BFF_URL=http://localhost:8001
REVIEW_BFF_PORT=8002
REVIEW_BFF_URL=http://localhost:8002
EDITOR_ADMIN_BFF_PORT=8003
EDITOR_ADMIN_BFF_URL=http://localhost:8003
CODEGEN_BFF_PORT=8008
CODEGEN_BFF_URL=http://localhost:8008

# -----------------------------------------------------------------------------
# Frontend micro frontends — ports 3000-3004, per architecture.md §8; codegen-mfe added on 3005
# -----------------------------------------------------------------------------
SHELL_PORT=3000
UPLOAD_MFE_PORT=3001
REVIEW_MFE_PORT=3002
EDITOR_MFE_PORT=3003
ADMIN_MFE_PORT=3004
CODEGEN_MFE_PORT=3005
# Base URLs the shell uses to fetch each remote's remoteEntry.js at runtime.
VITE_SHELL_REMOTE_UPLOAD_URL=http://localhost:3001/remoteEntry.js
VITE_SHELL_REMOTE_REVIEW_URL=http://localhost:3002/remoteEntry.js
VITE_SHELL_REMOTE_EDITOR_URL=http://localhost:3003/remoteEntry.js
VITE_SHELL_REMOTE_ADMIN_URL=http://localhost:3004/remoteEntry.js
VITE_SHELL_REMOTE_CODEGEN_URL=http://localhost:3005/remoteEntry.js

# -----------------------------------------------------------------------------
# Celery workers — orchestrator/celery_app.py
# -----------------------------------------------------------------------------
# One worker pool per queue so a slow queue doesn't starve others.
CELERY_QUEUE_INGESTION=ingestion
CELERY_QUEUE_STRUCTURAL=structural
CELERY_QUEUE_RECOMMENDATION=recommendation
CELERY_QUEUE_EPIC_STORY=epic_story
CELERY_QUEUE_CODEGEN=codegen
CELERY_WORKER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Shared project/runtime settings
# -----------------------------------------------------------------------------
# Default project_id used by local dev scripts / seed data when none is
# supplied explicitly.
DEFAULT_PROJECT_ID=acme-2026
LOG_LEVEL=INFO
ENVIRONMENT=local
